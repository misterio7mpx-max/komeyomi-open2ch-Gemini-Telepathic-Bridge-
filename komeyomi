       bindEvents: function() {
            const inputField = document.getElementById('komeyomi-chat-input');
            const sendBtn = document.getElementById('komeyomi-send-btn');
            const userSubtitleArea = document.getElementById('komeyomi-user-subtitle-area');
            const syncKomeCheck = document.getElementById('komeyomi-sync-kome');

            const handleSend = () => {
                const text = inputField.value.trim();
                if (text) {
                    const inner = userSubtitleArea.querySelector('.ky-user-text-inner');
                    if(inner) {
                        inner.innerText = text;
                    } else {
                        userSubtitleArea.textContent = text;
                    }
                    AudioEngine.playUser(text.replace(/\n/g, ' '));

                    // ▼ 修正: komeform を直接 Submit（送信）する方式に変更
                    if (syncKomeCheck && syncKomeCheck.checked) {
                        // サイトの空間に安全にテキストを渡すためエンコード
                        const safeText = encodeURIComponent(text);

                        const injectScript = document.createElement('script');
                        injectScript.textContent = `
                            (function() {
                                var komeEl = document.getElementById('kome');
                                var formEl = document.getElementById('komeform'); // 画像で発見したフォームID
                                if (!komeEl) return;

                                // 1. ページ空間側でテキストをセット（デコードして復元）
                                komeEl.value = decodeURIComponent("${safeText}");
                                komeEl.dispatchEvent(new Event('input', { bubbles: true }));
                                komeEl.dispatchEvent(new Event('change', { bubbles: true }));

                                // 2. フォームを送信（Submit）する
                                if (typeof $ !== 'undefined') {
                                    if (formEl) {
                                        // jQueryを使ってフォームを送信（サイト側のイベントを発火させる）
                                        $(formEl).submit();
                                    } else {
                                        // 万が一フォームが見つからなかった場合の予備（強力なEnter）
                                        var eDown = $.Event('keydown', { keyCode: 13, which: 13, key: 'Enter' });
                                        $(komeEl).trigger(eDown);
                                    }
                                } else {
                                    // jQueryが無い場合のネイティブ送信
                                    if (formEl) {
                                        formEl.dispatchEvent(new Event('submit', { cancelable: true, bubbles: true }));
                                    }
                                }
                            })();
                        `;
                        document.body.appendChild(injectScript);
                        injectScript.remove(); // 実行後すぐに削除

                        // 入力欄にフォーカスを戻す
                        inputField.focus();
                    }
                    // ▲ ここまで

                    inputField.value = '';
                }
            };

            if (inputField) {
                inputField.addEventListener('keydown', (e) => {
                    if (e.key === 'Enter') {
                        const isReversed = ConfigManager.get('enterSendReversed');
                        const shouldSend = isReversed ? e.shiftKey : !e.shiftKey;

                        if (shouldSend) {
                            e.preventDefault();
                            handleSend();
                        }
                    }
                });
            }
            if (sendBtn) {
                sendBtn.addEventListener('click', handleSend);
            }
        },

        spawnMarquee: function(text) {
