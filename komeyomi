                } catch(e) {
                    console.error("Komeyomi: 設定のパースに失敗しました", e);
                }
            }
        },

        save: function() {
            GM_setValue("Komeyomi_Config", JSON.stringify(this.data));
        },

        get: function(key) { return this.data[key]; },

        set: function(key, val) {
            this.data[key] = val;
            this.save();
            this.applyCssVariables();
        },

        applyCssVariables: function() {
            const root = document.documentElement;
            const marqueeH = Math.floor(this.data.sizeMarqueeFont * 1.05 * 3);
            const userH = Math.floor(this.data.sizeUserFont * 1.15 * 2);
            const totalH = marqueeH + userH;

            root.style.setProperty('--ky-marquee-h', `${marqueeH}px`);
            root.style.setProperty('--ky-user-h', `${userH}px`);
            root.style.setProperty('--ky-total-h', `${totalH}px`);
            root.style.setProperty('--ky-sidebar-w', `${this.data.sizeSidebarWidth}px`);
            root.style.setProperty('--ky-sidebar-font', `${this.data.sizeSidebarFont}px`);
            root.style.setProperty('--ky-sidebar-pad', `${this.data.sizeSidebarPad}px`);
            root.style.setProperty('--ky-sidebar-gap', `${this.data.sizeSidebarGap}px`);
            root.style.setProperty('--ky-marquee-font', `${this.data.sizeMarqueeFont}px`);
            root.style.setProperty('--ky-user-font', `${this.data.sizeUserFont}px`);

            root.style.setProperty('--ky-font-mq', this.data.fontMarquee);
            root.style.setProperty('--ky-font-user', this.data.fontUser);
            root.style.setProperty('--ky-font-sb', this.data.fontSidebar);

            root.style.setProperty('--ky-bg-marquee', this.data.colorMarqueeBg);
            root.style.setProperty('--ky-bg-user', this.data.colorUserBg);
            root.style.setProperty('--ky-bg-sidebar', this.data.colorSidebarBg);
            root.style.setProperty('--ky-bg-sidebar-item', this.data.colorSidebarItemBg);
            root.style.setProperty('--ky-marquee-speed', `${this.data.speedMarquee}s`);

            // ▼修正: CSSへの変数の渡し方を変更（左寄せと枠の中央維持の両立）
            const horzAlign = (this.data.posUserHorz === 'flex-start' || this.data.posUserHorz === 'left') ? 'left' : 'center';
            root.style.setProperty('--ky-user-vert', this.data.posUserVert);
            root.style.setProperty('--ky-user-text-align', horzAlign);

            if (typeof UIManager !== "undefined" && UIManager.pinKomediv) UIManager.pinKomediv();
        }
    }

    // =========================================================
    // 実行エントリポイント
    // =========================================================
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', () => StartupShield.build());
    } else {
        StartupShield.build();
    }

})();
