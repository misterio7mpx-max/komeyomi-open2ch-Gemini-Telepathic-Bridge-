// ... 以降の load: function() などは変更不要です

        load: function() {
            const saved = GM_getValue("Komeyomi_Config", null);
            if (saved) {
                try {
                    const parsed = JSON.parse(saved);
                    this.data = { ...this.data, ...parsed };

                    if (this.data.viewerVoicevoxIds && !parsed.viewerSpeakers) {
                        this.data.viewerSpeakers = this.data.viewerVoicevoxIds.map(id => ({ id: id, speed: 1.0, pitch: 0.0, intonation: 1.0 }));
                        delete this.data.viewerVoicevoxIds;
