    // =========================================================
    // [Phase 3] スレッド監視モジュール (CommentObserver)
    // =========================================================
    const CommentObserver = {
        lastRawText: "",

        process: function(rawText, isInitialLoad = false) {
            if (!rawText || rawText === this.lastRawText) return;
            this.lastRawText = rawText;

            let cleanText = rawText.replace(/>>\d+/g, '').replace(/https?:\/\/[\w/:%#\$&\?\(\)~\.=\+\-]+/g, 'URL省略').trim();
            if (!cleanText || cleanText.includes("Room:スレ限定") || cleanText.includes("komeを開始しますた")) return;

            UIManager.appendToSidebar(cleanText);
            if (!isInitialLoad) {
                UIManager.spawnMarquee(cleanText);
                AudioEngine.playViewer(cleanText);
            }
        },

        start: function() {
            const observer = new MutationObserver((mutations) => {
                let latestComment = null;
                for (const mutation of mutations) {
                    if (mutation.type === 'childList') {
                        for (const node of mutation.addedNodes) {
                            if (node.nodeType === 1) {
                                const baseNode = node.classList?.contains('kcomm_base') ? node : (node.querySelector && node.querySelector('.kcomm_base'));
                                if (baseNode) {
                                    const cloned = baseNode.cloneNode(true);
                                    const kdtag = cloned.querySelector('.kdtag');
                                    if (kdtag) kdtag.remove();
                                    latestComment = cloned.textContent.replace(/\s+/g, ' ').trim();
                                }
                            }
                        }
                    }
                }
                if (latestComment) this.process(latestComment, false);
            });

            const checkInterval = setInterval(() => {
                const targetBase = document.querySelector('.klog_content');
                if (targetBase) {
                    const existingComments = targetBase.querySelectorAll('.kcomm_base');
                    const last10 = Array.from(existingComments).slice(-10);

                    last10.forEach(baseNode => {
                        const cloned = baseNode.cloneNode(true);
                        const kdtag = cloned.querySelector('.kdtag');
                        if (kdtag) kdtag.remove();
                        const text = cloned.textContent.replace(/\s+/g, ' ').trim();
                        this.process(text, true);
                    });

                    observer.observe(targetBase, { childList: true, subtree: true });
                    clearInterval(checkInterval);
                    console.log("Komeyomi: コメントの監視を開始し、最新10件を読み込みました。");
                }
            }, 1000);
        }
    }
    // =========================================================
    // [Phase 4] 音声連携モジュール (AudioEngine)
    // =========================================================
    const AudioEngine = {
        isMuted: false, // ▼追加: 送信ストップ用のフラグ

        init: function() {
            console.log("Komeyomi: AudioEngineを待機状態にしました。");
        },

        playViewer: function(text) {
            // ▼追加: ミュート中はどこにもテキストを送信せず即終了
            if (this.isMuted) return;

            const engine = ConfigManager.get("viewerEngine");
            const speakers = ConfigManager.get("viewerSpeakers");
            if (!speakers || !speakers.length) return;

            const sp = speakers[Math.floor(Math.random() * speakers.length)];
            if (engine === "voicevox") {
                this.speakVoicevox(text, sp.id, ConfigManager.get("voicevoxUrl"), sp.speed, sp.pitch, sp.intonation);
            } else if (engine === "coeiroink") {
                this.speakVoicevox(text, sp.id, ConfigManager.get("coeiroinkUrl"), sp.speed, sp.pitch, sp.intonation);
            } else if (engine === "bouyomi") {
                this.speakBouyomi(text);
            } else if (engine === "seika") {
                this.speakSeika(text);
            }
        },

        playUser: function(text) {
            // ▼追加: ミュート中はどこにもテキストを送信せず即終了
            if (this.isMuted) return;

            const engine = ConfigManager.get("userEngine");
            const spd = ConfigManager.get("userVvSpeed");
            const pit = ConfigManager.get("userVvPitch");
            const int = ConfigManager.get("userVvIntonation");
            if (engine === "voicevox") {
                this.speakVoicevox(text, ConfigManager.get("userVoicevoxId"), ConfigManager.get("voicevoxUrl"), spd, pit, int);
            } else if (engine === "coeiroink") {
                this.speakVoicevox(text, ConfigManager.get("userVoicevoxId"), ConfigManager.get("coeiroinkUrl"), spd, pit, int);
            } else if (engine === "bouyomi") {
                this.speakBouyomi(text);
            } else if (engine === "seika") {
                this.speakSeika(text);
            }
        },

        speakVoicevox: function(text, speakerId, baseUrl, speed = 1.0, pitch = 0.0, intonation = 1.0) {
            GM_xmlhttpRequest({
                method: "POST",
                url: `${baseUrl}/audio_query?text=${encodeURIComponent(text)}&speaker=${speakerId}`,
                onload: (response) => {
                    if (response.status !== 200) return;

                    let queryObj;
                    try {
                        queryObj = JSON.parse(response.responseText);
                        queryObj.speedScale = speed;
                        queryObj.pitchScale = pitch;
                        queryObj.intonationScale = intonation;
                    } catch(e) { return; }

                    GM_xmlhttpRequest({
                        method: "POST",
                        url: `${baseUrl}/synthesis?speaker=${speakerId}`,
                        headers: { "Content-Type": "application/json" },
                        data: JSON.stringify(queryObj),
                        responseType: "arraybuffer",
                        onload: (synthResponse) => {
                            if (synthResponse.status !== 200) return;
                            const audioContext = new (window.AudioContext || window.webkitAudioContext)();
                            audioContext.decodeAudioData(synthResponse.response, (buffer) => {
                                const source = audioContext.createBufferSource();
                                source.buffer = buffer;
                                source.connect(audioContext.destination);
                                source.start(0);
                            });
                        }
                    });
                }
            });
        },

        speakBouyomi: function(text) {
            const targetUrl = `${ConfigManager.get("bouyomiUrl")}/talk?text=${encodeURIComponent(text)}`;
            GM_xmlhttpRequest({
                method: "GET",
                url: targetUrl,
                onerror: (error) => {
                    console.error("❌ 棒読みちゃん通信エラー! TampermonkeyのXHR設定か、URLが間違っている可能性があります。", error);
                }
            });
        },

        fetchSpeakers: function(baseUrl, callback) {
            GM_xmlhttpRequest({
                method: "GET",
                url: `${baseUrl}/speakers`,
                onload: (res) => {
                    if (res.status !== 200) return;
                    try {
                        const speakers = JSON.parse(res.responseText);
                        const list = [];
                        speakers.forEach(s => {
                            s.styles.forEach(style => {
                                list.push({ id: style.id, name: `${s.name} (${style.name})` });
                            });
                        });
                        callback(list);
                    } catch (e) { console.error("Komeyomi: 話者リスト取得失敗", e); }
                }
            });
        },

        speakSeika: function(text) {
            GM_xmlhttpRequest({
                method: "GET",
                url: `${ConfigManager.get("seikaUrl")}/talk?text=${encodeURIComponent(text)}`,
                onerror: (err) => console.log("Seika通信エラー:", err)
            });
        }
    }
    // =========================================================
