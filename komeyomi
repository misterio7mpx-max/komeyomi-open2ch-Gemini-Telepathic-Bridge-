                    e.preventDefault();
                    let val = parseFloat(s.value) + (e.deltaY < 0 ? 0.01 : -0.01);
                    val = Math.round(val * 100) / 100;
                    val = Math.max(parseFloat(s.min), Math.min(parseFloat(s.max), val));
